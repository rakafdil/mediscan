--
-- Name: user_allergies Allow delete user allergies; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow delete user allergies" ON public.user_allergies FOR DELETE TO authenticated USING ((id = auth.uid()));


--
-- Name: user_disease_history Allow delete user disease history; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow delete user disease history" ON public.user_disease_history FOR DELETE TO authenticated USING ((id = auth.uid()));


--
-- Name: allergy Allow insert allergy; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow insert allergy" ON public.allergy FOR INSERT TO authenticated WITH CHECK ((auth.uid() IS NOT NULL));


--
-- Name: disease Allow insert disease; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow insert disease" ON public.disease FOR INSERT TO authenticated WITH CHECK ((auth.uid() IS NOT NULL));


--
-- Name: location Allow insert for authenticated users; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow insert for authenticated users" ON public.location FOR INSERT TO authenticated WITH CHECK ((auth.role() = 'authenticated'::text));


--
-- Name: user_location Allow insert for own user_location link; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow insert for own user_location link" ON public.user_location FOR INSERT TO authenticated WITH CHECK ((user_id = auth.uid()));


--
-- Name: user_allergies Allow insert user allergies; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow insert user allergies" ON public.user_allergies FOR INSERT TO authenticated WITH CHECK ((id = auth.uid()));


--
-- Name: user_disease_history Allow insert user disease history; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow insert user disease history" ON public.user_disease_history FOR INSERT TO authenticated WITH CHECK ((id = auth.uid()));


--
-- Name: allergy Allow read allergy; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow read allergy" ON public.allergy FOR SELECT TO authenticated USING (true);


--
-- Name: disease Allow read disease; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow read disease" ON public.disease FOR SELECT TO authenticated USING (true);


--
-- Name: user_allergies Allow read user allergies; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow read user allergies" ON public.user_allergies FOR SELECT TO authenticated USING ((id = auth.uid()));


--
-- Name: user_disease_history Allow read user disease history; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow read user disease history" ON public.user_disease_history FOR SELECT TO authenticated USING ((id = auth.uid()));


--
-- Name: location Allow select for own location; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow select for own location" ON public.location FOR SELECT TO authenticated USING ((EXISTS ( SELECT 1
   FROM public.user_location
  WHERE ((user_location.location_id = location.location_id) AND (user_location.user_id = auth.uid())))));


--
-- Name: user Allow select for own profile; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow select for own profile" ON public."user" FOR SELECT TO authenticated USING ((id = auth.uid()));


--
-- Name: user_location Allow select for own user_location link; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow select for own user_location link" ON public.user_location FOR SELECT TO authenticated USING ((user_id = auth.uid()));


--
-- Name: location Allow update for own location; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow update for own location" ON public.location FOR UPDATE TO authenticated USING ((EXISTS ( SELECT 1
   FROM public.user_location
  WHERE ((user_location.location_id = location.location_id) AND (user_location.user_id = auth.uid())))));


--
-- Name: user Allow update for own profile; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow update for own profile" ON public."user" FOR UPDATE TO authenticated USING ((id = auth.uid()));


--
-- Name: allergy Authenticated users can read allergies.; Type: POLICY; Schema: public; Owner: postgres
